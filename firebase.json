{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*"
    ],
    "rewrites": [
      {
        "source": "/code-sense/**",
        "destination": "/code-sense/index.html"
      },
      {
        "source": "/articles/**",
        "destination": "/articles/index.html"
      }
    ]
  }
}
